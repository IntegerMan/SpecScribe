{
  "name": "specscribe-status",
  "displayName": "SpecScribe Status",
  "description": "Read-only, live-updating in-editor view of a SpecScribe project's dashboard and epics surfaces. All rendering happens in the SpecScribe C# core; this extension is a thin host shim (ADR 0005).",
  "version": "0.1.0",
  "private": true,
  "publisher": "specscribe",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:_bmad/config.toml",
    "workspaceContains:_bmad-output"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "restrictedConfigurations": [
        "specscribe.toolPath"
      ]
    }
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "specscribe.openStatus",
        "category": "SpecScribe",
        "title": "Open Status"
      },
      {
        "command": "specscribe.openDashboard",
        "category": "SpecScribe",
        "title": "Open Dashboard"
      },
      {
        "command": "specscribe.openEpics",
        "category": "SpecScribe",
        "title": "Open Epics"
      },
      {
        "command": "specscribe.refresh",
        "category": "SpecScribe",
        "title": "Refresh Status"
      },
      {
        "command": "specscribe.openGeneratedSite",
        "category": "SpecScribe",
        "title": "Open Generated Site"
      },
      {
        "command": "specscribe.generateSite",
        "category": "SpecScribe",
        "title": "Generate Full Site"
      },
      {
        "command": "specscribe.watch",
        "category": "SpecScribe",
        "title": "Watch"
      },
      {
        "command": "specscribe.openProjectSettings",
        "category": "SpecScribe",
        "title": "Open Project Settings"
      },
      {
        "command": "specscribe.refreshOutline",
        "category": "SpecScribe",
        "title": "Refresh Outline",
        "icon": "$(refresh)"
      },
      {
        "command": "specscribe.revealSurface",
        "category": "SpecScribe",
        "title": "Reveal in Panel"
      },
      {
        "command": "specscribe.openSource",
        "category": "SpecScribe",
        "title": "Open Source File",
        "icon": "$(go-to-file)"
      },
      {
        "command": "specscribe.copyHelperPrompt",
        "category": "SpecScribe",
        "title": "Copy Helper Prompt",
        "icon": "$(clippy)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "specscribe",
          "title": "SpecScribe",
          "icon": "media/specscribe-outline.svg"
        }
      ]
    },
    "views": {
      "specscribe": [
        {
          "id": "specscribe.outline",
          "name": "Project Outline",
          "icon": "media/specscribe-outline.svg",
          "contextualTitle": "SpecScribe"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "specscribe.outline",
        "when": "!specscribe.projectDetected",
        "contents": "No SpecScribe project detected in this folder.\nOpen a folder that contains a `_bmad-output` directory (or a `_bmad/config.toml`) to see its epics and stories here.\n[Open Folder](command:vscode.openFolder)"
      }
    ],
    "colors": [
      {
        "id": "specscribe.status.done",
        "description": "SpecScribe status accent — Done (green). Mirrors the Story 6.5 webview theme tuning.",
        "defaults": { "light": "#3f7a35", "dark": "#8fbb82", "highContrast": "#7fe08a", "highContrastLight": "#2f5a2a" }
      },
      {
        "id": "specscribe.status.review",
        "description": "SpecScribe status accent — In review (deep teal).",
        "defaults": { "light": "#1e4a5a", "dark": "#4d9ab5", "highContrast": "#4aa8ff", "highContrastLight": "#0e3947" }
      },
      {
        "id": "specscribe.status.active",
        "description": "SpecScribe status accent — In development (teal).",
        "defaults": { "light": "#2e6b7a", "dark": "#5fb3c6", "highContrast": "#56d0ff", "highContrastLight": "#14606f" }
      },
      {
        "id": "specscribe.status.ready",
        "description": "SpecScribe status accent — Ready for dev (gold).",
        "defaults": { "light": "#b8860b", "dark": "#e6b52e", "highContrast": "#ffcc33", "highContrastLight": "#7a5600" }
      },
      {
        "id": "specscribe.status.drafted",
        "description": "SpecScribe status accent — Drafted (pale gold).",
        "defaults": { "light": "#8a6d0a", "dark": "#e8d9a8", "highContrast": "#f0dfa8", "highContrastLight": "#5c4807" }
      },
      {
        "id": "specscribe.status.pending",
        "description": "SpecScribe status accent — Pending (tan-grey).",
        "defaults": { "light": "#6b6459", "dark": "#cbc4b6", "highContrast": "#d8d8d8", "highContrastLight": "#46413a" }
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "specscribe.openStatus",
          "when": "specscribe.projectDetected"
        },
        {
          "command": "specscribe.openDashboard",
          "when": "specscribe.projectDetected"
        },
        {
          "command": "specscribe.openEpics",
          "when": "specscribe.projectDetected"
        },
        {
          "command": "specscribe.refresh",
          "when": "specscribe.projectDetected"
        },
        {
          "command": "specscribe.openGeneratedSite",
          "when": "specscribe.projectDetected"
        },
        {
          "command": "specscribe.generateSite",
          "when": "specscribe.projectDetected"
        },
        {
          "command": "specscribe.watch",
          "when": "specscribe.projectDetected"
        },
        {
          "command": "specscribe.openProjectSettings",
          "when": "specscribe.projectDetected"
        },
        {
          "command": "specscribe.refreshOutline",
          "when": "specscribe.projectDetected"
        },
        {
          "command": "specscribe.revealSurface",
          "when": "false"
        },
        {
          "command": "specscribe.openSource",
          "when": "false"
        },
        {
          "command": "specscribe.copyHelperPrompt",
          "when": "false"
        }
      ],
      "explorer/context": [
        {
          "command": "specscribe.openStatus",
          "when": "specscribe.projectDetected && resourcePath =~ /(^|\\/)_bmad-output(\\/|$)/",
          "group": "navigation@99"
        }
      ],
      "editor/title": [
        {
          "command": "specscribe.openStatus",
          "when": "specscribe.projectDetected && resourceExtname == .md && resourceDirname =~ /(^|\\/)_bmad-output(\\/|$)/",
          "group": "navigation@99"
        }
      ],
      "view/title": [
        {
          "command": "specscribe.refreshOutline",
          "when": "view == specscribe.outline",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "specscribe.openSource",
          "when": "view == specscribe.outline && viewItem =~ /-source/",
          "group": "inline@1"
        },
        {
          "command": "specscribe.openSource",
          "when": "view == specscribe.outline && viewItem =~ /-source/",
          "group": "navigation@1"
        },
        {
          "command": "specscribe.copyHelperPrompt",
          "when": "view == specscribe.outline && viewItem =~ /-helper/",
          "group": "inline@2"
        },
        {
          "command": "specscribe.copyHelperPrompt",
          "when": "view == specscribe.outline && viewItem =~ /-helper/",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "SpecScribe",
      "properties": {
        "specscribe.toolPath": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "markdownDescription": "Path to the SpecScribe tool the extension spawns for rendering — an executable, or a `SpecScribe.dll` to run via `dotnet`. Leave empty to use the binary bundled with the extension (when packaged) or `specscribe` on PATH."
        },
        "specscribe.openLocation": {
          "type": "string",
          "enum": [
            "beside",
            "active"
          ],
          "enumDescriptions": [
            "Open the SpecScribe Status panel beside the active editor.",
            "Open the SpecScribe Status panel in the active editor column."
          ],
          "default": "beside",
          "scope": "window",
          "markdownDescription": "Where the SpecScribe Status panel opens relative to your editor. A host/window concern — project behavior (source/ADR roots, output, deep-git) lives in the directory-scoped `.specscribe` file, not here."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "package": "node esbuild.js --production && npx --yes @vscode/vsce@latest package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.6.0"
  }
}
