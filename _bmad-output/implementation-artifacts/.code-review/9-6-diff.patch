+    public static bool AreNearDuplicates(string a, string b)
+    {
+        var ta = SignificantTokens(a);
+        var tb = SignificantTokens(b);
+        if (ta.Count == 0 || tb.Count == 0) return false;
+
+        var shared = ta.Intersect(tb, StringComparer.Ordinal).ToList();
