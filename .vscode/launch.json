{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "SpecScribe: Open Live Site (Edge)",
      "type": "pwa-msedge",
      "request": "launch",
      "url": "file:///${workspaceFolder}/SpecScribeOutput/index.html",
      "webRoot": "${workspaceFolder}/SpecScribeOutput",
      "preLaunchTask": "SpecScribe: Generate Site"
    },
    {
      "name": "SpecScribe: Open Live Site (Chrome)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "file:///${workspaceFolder}/SpecScribeOutput/index.html",
      "webRoot": "${workspaceFolder}/SpecScribeOutput",
      "preLaunchTask": "SpecScribe: Generate Site"
    }
  ]
}
